#!/usr/bin/env bash
set -euo pipefail

SHOCK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

subcommand="${1:-}"
if [[ -z "$subcommand" ]]; then
  echo "Usage: shock <command> [args...]" >&2
  echo "" >&2
  echo "Commands:" >&2
  for cmd in "$SHOCK_DIR"/cli/*; do
    [[ -x "$cmd" ]] && echo "  $(basename "$cmd")" >&2
  done
  exit 1
fi
shift

cli_script="$SHOCK_DIR/cli/$subcommand"
if [[ ! -f "$cli_script" ]]; then
  echo "shock: unknown command '$subcommand'" >&2
  exit 1
fi

exec "$cli_script" "$@"
